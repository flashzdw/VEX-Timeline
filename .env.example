# Supabase Configuration
# Copy this file to .env.local and fill in your actual values for local development
# DO NOT commit .env.local to git!

# Your Supabase Project URL (from Supabase Dashboard -> Project Settings -> API)
SUPABASE_URL=

# Your Supabase Anon Public Key (from Supabase Dashboard -> Project Settings -> API)
SUPABASE_ANON_KEY=
